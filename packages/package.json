{
  "name": "gp-ui-dialian",
  "version": "1.0.0",
  "description": "GP-UI 基于 Vue3 的组件库",
  "type": "module",
  "main": "./dist/gp-ui.umd.js",
  "module": "./dist/gp-ui.es.js",
  "unpkg": "./dist/gp-ui.umd.js",
  "jsdelivr": "./dist/gp-ui.umd.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/gp-ui.es.js",
      "require": "./dist/gp-ui.umd.js",
      "types": "./dist/index.d.ts"
    },
    "./dist/style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && vue-tsc --emitDeclarationOnly",
    "pub": "npm publish --access public"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "sass": "^1.70.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.9.1",
    "vue-tsc": "^2.0.0"
  },
  "author": "dalianfff",
  "license": "MIT"
}
